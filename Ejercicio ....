Algoritmo ejercicio_23
	Definir num, i Como Entero;
	//Se crea la dimension 
	Dimension num[5]
	//Se hace el for para que el usuario ingrese los 5 numeros
	Para i<- 1 hasta 5 Con Paso 1 Hacer
		Escribir "ingrese el numero: ", i
		Leer num[i]
	FinPara
	//Se hace el for para imprimir los numeros en pantalla
	Para i<- 1 Hasta 5 Con Paso  1 hacer
		Escribir num[i]
	FinPara
FinAlgoritmo
